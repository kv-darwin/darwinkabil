<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
  :root {
    --bg: #0e1116;
    --bg-soft: #161a22;
    --bg-card: #1a1f29;
    --ink: #e8e6e1;
    --ink-soft: #a8a59e;
    --ink-muted: #6b6862;
    --accent: #d4a574;
    --accent-bright: #e6b87a;
    --accent-dim: #8a6a4a;
    --line: rgba(232, 230, 225, 0.08);
    --line-strong: rgba(232, 230, 225, 0.16);
    --serif: 'Fraunces', Georgia, serif;
    --sans: 'Inter', system-ui, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--ink);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1000;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.5rem 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    backdrop-filter: blur(12px);
    background: rgba(14, 17, 22, 0.75);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
  }
  nav.scrolled { border-bottom-color: var(--line); }

  .logo {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .logo em {
    font-style: italic;
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .nav-links a {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.25s;
    position: relative;
  }
  .nav-links a:hover { color: var(--ink); }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.3s ease;
  }
  .nav-links a:hover::after { width: 100%; }

  .hero {
    min-height: 100vh;
    padding: 8rem 4rem 4rem;
    display: grid;
    grid-template-columns: 1fr;
    align-content: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 20%;
    right: -10%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, rgba(212, 165, 116, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.1s forwards;
  }
  .hero-meta::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--accent);
  }

  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(3rem, 9vw, 8rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
    max-width: 1200px;
  }
  .hero h1 .line { display: block; overflow: hidden; }
  .hero h1 .line span {
    display: inline-block;
    transform: translateY(110%);
    animation: slideUp 1s cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
  }
  .hero h1 .line:nth-child(1) span { animation-delay: 0.2s; }
  .hero h1 .line:nth-child(2) span { animation-delay: 0.35s; }
  .hero h1 .line:nth-child(3) span { animation-delay: 0.5s; }

  .hero h1 em {
    font-style: italic;
    color: var(--accent);
    font-weight: 300;
  }

  .hero-tagline {
    font-size: 1.15rem;
    color: var(--ink-soft);
    max-width: 620px;
    margin-bottom: 3rem;
    line-height: 1.6;
    opacity: 0;
    animation: fadeUp 0.8s 0.9s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.8s 1.1s forwards;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.8rem;
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--line-strong);
    background: transparent;
    color: var(--ink);
    transition: all 0.3s ease;
    cursor: pointer;
    border-radius: 2px;
  }
  .btn:hover {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }
  .btn-primary:hover {
    background: var(--accent-bright);
    border-color: var(--accent-bright);
  }
  .btn svg { width: 14px; height: 14px; }

  section { padding: 8rem 4rem; position: relative; }

  .section-label {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .section-label::before {
    content: counter(section, decimal-leading-zero);
    font-family: var(--mono);
    color: var(--ink-muted);
  }

  body { counter-reset: section; }
  section { counter-increment: section; }

  .section-title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 4rem;
    max-width: 900px;
  }
  .section-title em {
    font-style: italic;
    color: var(--accent);
  }

  .about {
    border-top: 1px solid var(--line);
    background: var(--bg-soft);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 6rem;
    align-items: start;
  }

  .about-portrait { position: sticky; top: 8rem; }

  .portrait-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .portrait-image {
    width: 100%;
    aspect-ratio: 4/5;
    position: relative;
    overflow: hidden;
    background: var(--bg-card);
  }
  .portrait-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    display: block;
    transition: filter 0.4s ease;
  }
  .portrait-fallback {
    display: none;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 8rem;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--accent);
  }
  .portrait-fallback em { font-style: italic; }
  .portrait-meta {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: var(--bg-card);
  }

  .about-content p {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 300;
    line-height: 1.5;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .about-content p:last-child { margin-bottom: 0; }
  .about-content p strong { font-weight: 500; color: var(--accent); }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--line);
  }
  .stat-num {
    font-family: var(--serif);
    font-size: 3.5rem;
    font-weight: 400;
    line-height: 1;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .stat-num em { font-style: italic; }
  .stat-label {
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.4;
  }

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .expertise-card {
    padding: 3rem 2.5rem;
    background: var(--bg);
    transition: background 0.4s ease;
    position: relative;
  }
  .expertise-card:hover { background: var(--bg-soft); }
  .expertise-card:hover .expertise-num { color: var(--accent); }

  .expertise-num {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
    transition: color 0.3s ease;
  }

  .expertise-card h3 {
    font-family: var(--serif);
    font-size: 1.8rem;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .expertise-card h3 em { font-style: italic; color: var(--accent); }

  .expertise-card p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .expertise-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    font-family: var(--mono);
    font-size: 0.7rem;
    padding: 0.35rem 0.75rem;
    background: rgba(212, 165, 116, 0.08);
    border: 1px solid rgba(212, 165, 116, 0.2);
    color: var(--accent);
    border-radius: 2px;
    letter-spacing: 0.05em;
  }

  .experience {
    background: var(--bg-soft);
    border-top: 1px solid var(--line);
  }

  .timeline {
    position: relative;
    max-width: 1100px;
  }

  .job {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 4rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.4s ease;
  }
  .job:hover { padding-left: 1rem; }
  .job:last-child { border-bottom: none; }

  .job-period {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--ink-muted);
    letter-spacing: 0.1em;
    padding-top: 0.5rem;
  }
  .job-period .role-tag {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.2rem 0.6rem;
    background: rgba(212, 165, 116, 0.1);
    color: var(--accent);
    border-radius: 2px;
    font-size: 0.7rem;
  }

  .job-content h3 {
    font-family: var(--serif);
    font-size: 1.7rem;
    font-weight: 400;
    margin-bottom: 0.3rem;
    letter-spacing: -0.02em;
  }
  .job-company {
    font-size: 0.9rem;
    color: var(--accent);
    margin-bottom: 1.2rem;
    font-weight: 500;
  }
  .job-content p {
    color: var(--ink-soft);
    line-height: 1.7;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }
  .job-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.2rem;
  }
  .job-bullets {
    list-style: none;
    margin-bottom: 1rem;
  }
  .job-bullets li {
    padding: 0.4rem 0;
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.6;
    padding-left: 1.5rem;
    position: relative;
  }
  .job-bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .certs-wrap { border-top: 1px solid var(--line); }

  .certs-section { margin-bottom: 3rem; }
  .certs-section:last-child { margin-bottom: 0; }
  .certs-subtitle {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-style: italic;
    color: var(--accent);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .certs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .cert {
    padding: 1.25rem;
    border: 1px solid var(--line);
    background: var(--bg-card);
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.3s ease;
    border-radius: 4px;
  }
  .cert:hover {
    border-color: var(--accent-dim);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }
  .cert-badge {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .cert-badge img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }
  .cert:hover .cert-badge img {
    transform: scale(1.08);
  }
  /* Logo-only badges (Power BI, Tableau, etc.) get a circular white background */
  .cert-badge.logo-frame {
    background: #fff;
    border-radius: 50%;
    padding: 10px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }
  .cert-badge.logo-frame.dark {
    background: #1a1a1a;
  }
  .cert-name {
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
  }
  .cert-issuer {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--ink-muted);
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }
  .cert-grid-superbadges {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.85rem;
  }
  .cert-grid-superbadges .cert {
    padding: 1rem;
  }
  .cert-grid-superbadges .cert-badge {
    width: 54px;
    height: 54px;
  }
  .cert-grid-superbadges .cert-name {
    font-size: 0.85rem;
  }
  /* Agentblazer status callout */
  .agentblazer-card {
    margin-top: 2rem;
    padding: 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(212, 165, 116, 0.08), rgba(212, 165, 116, 0.02));
    border: 1px solid rgba(212, 165, 116, 0.25);
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .agentblazer-icon {
    font-size: 2.5rem;
    line-height: 1;
  }
  .agentblazer-content h4 {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
    color: var(--accent);
  }
  .agentblazer-content p {
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .projects {
    background: var(--bg-soft);
    border-top: 1px solid var(--line);
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project {
    padding: 2.5rem;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 4px;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
  }
  .project::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.4s ease;
  }
  .project:hover { border-color: var(--line-strong); }
  .project:hover::before { transform: scaleY(1); }

  .project-num {
    font-family: var(--serif);
    font-style: italic;
    font-size: 4rem;
    font-weight: 300;
    color: var(--accent);
    line-height: 0.8;
    margin-bottom: 1rem;
  }
  .project-domain {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .project h3 {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .project h3 em { font-style: italic; color: var(--accent); }

  .project-desc {
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .project-highlights {
    list-style: none;
    margin-bottom: 1.5rem;
  }
  .project-highlights li {
    padding: 0.5rem 0;
    color: var(--ink);
    font-size: 0.92rem;
    line-height: 1.6;
    padding-left: 1.5rem;
    position: relative;
  }
  .project-highlights li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--mono);
  }

  .edu-pub-wrap { border-top: 1px solid var(--line); }
  .edu-pub-grid {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    max-width: 900px;
  }

  .edu-block h3, .pub-block h3 {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 2rem;
    color: var(--accent);
    font-style: italic;
  }

  .edu-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--line);
  }
  .edu-card:last-child { border-bottom: none; }
  .edu-degree {
    font-family: var(--serif);
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }
  .edu-school {
    color: var(--ink-soft);
    font-size: 0.9rem;
    margin-bottom: 0.3rem;
  }
  .edu-detail {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }

  .pub-card {
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--line);
  }
  .pub-card:last-child { border-bottom: none; }
  .pub-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.4;
    margin-bottom: 0.4rem;
  }
  .pub-meta {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }
  .pub-link {
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.25s;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .pub-link:hover { color: var(--accent-bright); }

  .contact {
    background: var(--bg);
    border-top: 1px solid var(--line);
    text-align: center;
    padding: 10rem 4rem 6rem;
  }

  .contact-label {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .contact h2 {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 7vw, 6rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
  }
  .contact h2 em {
    font-style: italic;
    color: var(--accent);
  }

  .contact-email {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--ink);
    text-decoration: none;
